# =============================================================================
# EaseToLearn Video Factory — DigitalOcean Dev Server Environment (Spring Boot)
# =============================================================================

# --- Server Port ---
PORT=8081

# --- Spring Active Profile ---
# Set to 'prod' so Spring Boot uses external DB, external RabbitMQ, etc.
SPRING_PROFILES_ACTIVE=prod

# --- Connection to the Video Factory (Mac Mini) ---
# Point to the Mac Mini's WireGuard IP (10.0.1.1) running the Python Factory API
FACTORY_BASE_URL=http://10.0.1.1:8000
FACTORY_API_KEY=etl_factory_prod_8291_secret
FACTORY_WEBHOOK_SECRET=etl_webhook_local_secret

# --- Spring Boot Self Base URL (DigitalOcean Host) ---
# This is passed to the Mac Mini so it knows where to send webhooks back
APP_SELF_BASE_URL=http://165.232.185.159:8081

# --- Central PostgreSQL Database (on DigitalOcean or RDS) ---
DB_URL=jdbc:postgresql://postgres-host-ip:5432/etl_video_generation
DB_USERNAME=root
DB_PASSWORD=your_db_password

# --- Shared RabbitMQ Broker ---
RABBITMQ_HOST=rabbitmq-host-ip
RABBITMQ_USER=etl
RABBITMQ_PASS=your_rabbitmq_password
RABBITMQ_VHOST=/
