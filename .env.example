# ── API KEYS ───────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
HEYGEN_API_KEY=your_heygen_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
HIGGSFIELD_API_ID=your_higgsfield_api_id
HIGGSFIELD_API_KEY=your_higgsfield_api_key

# ── LLM SETTINGS ───────────────────────────────────────────
# Options: groq | google | local | openai
LLM_PROVIDER=groq
LOCAL_LLM_URL=http://localhost:11434/v1
LOCAL_LLM_MODEL=gemma:7b

# ── SEARCH (SEARXNG) ────────────────────────────────────────
SEARXNG_URL=http://localhost:8080
SEARXNG_RESULTS_LIMIT=5

# ── INFRASTRUCTURE ──────────────────────────────────────────
PORT=8000
REDIS_URL=redis://localhost:6379/0
IDEMPOTENCY_TTL=3600
LOCAL_CDN_URL=http://localhost:8000
AUTO_DELETE_JOB_DIR=true
HYGIENE_RETENTION_HOURS=24
