# EaseToLearn SearXNG Standalone Configuration

# Base URL for the instance (affects UI and internal links)
SEARXNG_BASE_URL=http://localhost:8080/

# The port SearXNG will bind to inside the container
SEARXNG_PORT=8080

# Bind address (0.0.0.0 for docker, 127.0.0.1 for local dev)
SEARXNG_BIND_ADDRESS=0.0.0.0

# Secret Key (CRITICAL: Change this for production)
SEARXNG_SECRET_KEY=industrial_factory_secret_key
