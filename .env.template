# Core Orchestration
ANTHROPIC_API_KEY=your_anthropic_api_key  # For Director & Healer
GROQ_API_KEY=your_groq_api_key          # For PPT Planning & Script Fixing

# Multimedia Generation
GEMINI_API_KEY=your_gemini_api_key      # For Vision & Imagen
ELEVENLABS_API_KEY=your_elevenlabs_key  # For TTS

# B-Roll & Avatar Generation
HIGGSFIELD_API_ID=your_id
HIGGSFIELD_API_KEY=your_key
HEYGEN_API_KEY=your_heygen_key

# LLM Selection
LLM_PROVIDER=groq # Choices: groq, google, local
LOCAL_LLM_URL=http://localhost:11434/v1 # Address of your Mac Mini (Ngrok/WireGuard/Tunnel)
LOCAL_LLM_MODEL=gemma:4b # Model name running on Mac Mini
SEARXNG_URL=http://localhost:8080 # Metasearch engine URL
SEARXNG_RESULTS_LIMIT=5

# Disk Hygiene (Staging Area Cleanup)
HYGIENE_RETENTION_HOURS=24
HYGIENE_CHECK_INTERVAL_SECONDS=3600
AUTO_DELETE_JOB_DIR=false  # Set to true to delete immediately, false to use 24h retention

