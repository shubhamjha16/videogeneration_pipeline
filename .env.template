# EaseToLearn Video Factory — Environment Template

# ── API Keys ──────────────────────────────────────────────────────────────────
ELEVENLABS_API_KEY=your_key_here
GEMINI_API_KEY=your_key_here
HEYGEN_API_KEY=your_key_here
HIGGSFIELD_API_ID=your_key_here
HIGGSFIELD_API_KEY=your_key_here
GROQ_API_KEY=your_key_here
FACTORY_API_KEY=change_this_for_production

# ── Research Node (DECOUPLED) ─────────────────────────────────────────────────
# Point this to your standalone SearXNG instance (e.g. Mac Mini)
# If running locally via docker-compose, this defaults to localhost:8080
SEARXNG_URL=http://localhost:8080
SEARXNG_RESULTS_LIMIT=5

# ── LLM Configuration ─────────────────────────────────────────────────────────
LLM_PROVIDER=groq
LOCAL_LLM_URL=http://localhost:11434/v1
LOCAL_LLM_MODEL=gemma:4b

# ── Storage & Hygiene ─────────────────────────────────────────────────────────
S3_BUCKET=easetolearn-videos
AWS_REGION=ap-south-1
HYGIENE_RETENTION_HOURS=24
HYGIENE_CHECK_INTERVAL_SECONDS=3600

# ── Pipeline Meta ─────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=*
WEBHOOK_URL=https://api.easetolearn.com/videos/webhook
