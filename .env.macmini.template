# =============================================================================
# EaseToLearn Video Factory — Mac Mini Staging Environment
# Copy to `.env` (same directory as docker-compose.macmini.yaml) and fill in.
# Variable NAMES match the AWS Secrets Manager secret 1:1, so migrating to
# production is copy-paste, not translation.
#
# Note: ENV, S3_BUCKET, DATABASE_URL, REDIS_URL, SEARXNG_URL, QDRANT_HOST/PORT
# are fixed for the Mini and set directly in the compose file. On AWS those same
# names are sourced from Secrets Manager / the task definition instead.
# =============================================================================

# --- CRITICAL: the Mini's WireGuard URL (NOT localhost) -----------------------
# Portal playback and Tony AI callbacks both resolve through this. If left as
# localhost, playback silently breaks for anyone off the box.
LOCAL_CDN_URL=http://<MAC_MINI_WIREGUARD_IP>:8000

# --- Local Postgres (container) ----------------------------------------------
POSTGRES_PASSWORD=change-me-staging

# --- RabbitMQ ----------------------------------------------------------------
RABBITMQ_USER=etl
RABBITMQ_PASS=change-me-staging
RABBITMQ_VHOST=/

# --- Qdrant (blank for the local container) ----------------------------------
QDRANT_API_KEY=

# --- Integration security (MUST match Tony AI's Spring Boot config) ----------
FACTORY_API_KEY=change-me
FACTORY_WEBHOOK_SECRET=change-me

# --- Provider keys -----------------------------------------------------------
ANTHROPIC_API_KEY=
GROQ_API_KEY=
GEMINI_API_KEY=
ELEVENLABS_API_KEY=
HEYGEN_API_KEY=
HIGGSFIELD_API_KEY=
OPENAI_API_KEY=
