# Python virtual environment — never copy into image
venv/
.venv/
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
dist/
build/
.eggs/

# Generated output — mounted as EFS volume in ECS
output/
media/

# Local audio/video files
*.mp4
*.m4a
*.mp3
*.wav
*.aiff

# Images generated during testing
*.png
*.jpg
*.jpeg

# Secrets — injected via ECS task definition env vars
.env
*.env

# macOS
.DS_Store
.AppleDouble
.LSOverride

# IDE
.idea/
.vscode/
*.swp
*.swo

# Git
.git/
.gitignore

# Test files
test_*.py
*_test.py
e2e_*.py

# HTML source files used for local testing
*_source.html
bpf_source.html
bpf_narration.txt

# Jobs persistence file — starts fresh in each container
jobs.json

# Temporary masterclass scripts (one-off test files)
*_masterclass.py
*_mission.py
*_scene.py
iliac_*.py
calcium_*.py
carpopedal_*.py
merge_*.py
